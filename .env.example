# Copy this file to .env only for local development.
# Never commit the real .env file.

# PostgreSQL JDBC connection used by Spring Boot and Flyway.
DB_URL=jdbc:postgresql://localhost:5432/verdenote
DB_USERNAME=postgres
DB_PASSWORD=change-me

# Long random secret used by Spring Security remember-me tokens.
# Production: generate a strong value and keep it private.
VERDENOTE_REMEMBER_ME_KEY=replace-with-a-long-random-secret

# Shared secret used only between verdenote-node and verdenote-core.
# The value must be exactly the same in both services.
VERDENOTE_REALTIME_SERVICE_SECRET=replace-with-a-long-random-service-secret

# Comma-separated frontend origins allowed to send credentialed requests.
# Production example: https://app.example.com
VERDENOTE_CORS_ALLOWED_ORIGINS=http://localhost:3000

# Local HTTP development can use false. Production behind HTTPS must use true.
VERDENOTE_COOKIE_SECURE=false
